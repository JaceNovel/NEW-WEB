generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
}

enum PlayerStatus {
  ROI
  CHALLENGER
  PLAYER
  ELIMINATED
}

enum GameMode {
  SPAM
  ONETAP
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  REJECTED
  FINISHED
}

enum TournamentStage {
  REGISTRATION
  LOCKED
  ACTIVE
  FINALIZED
}

model Player {
  id           String       @id @default(cuid())
  pseudo       String       @unique
  email        String?      @unique
  freefireId   String       @unique
  countryCode  String       @default("FR")
  gameMode     GameMode
  logoUrl      String
  credits      Int          @default(5)
  weeklyCreditsGrantedAt DateTime?
  points       Int          @default(0)
  status       PlayerStatus @default(PLAYER)
  role         Role         @default(PLAYER)
  passwordHash String
  wins         Int          @default(0)
  losses       Int          @default(0)
  isSeededTop10 Boolean     @default(false)
  seededTop20At DateTime?
  finalRank     Int?
  purchasedById String?
  purchasedAt   DateTime?
  alliancePending Boolean   @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  matchesAsP1  Match[]      @relation("MatchPlayer1")
  matchesAsP2  Match[]      @relation("MatchPlayer2")
  matchesWon   Match[]      @relation("MatchWinner")

  challengesSent     Challenge[] @relation("ChallengeChallenger")
  challengesReceived Challenge[] @relation("ChallengeDefender")
  roiTournaments     TournamentConfig[] @relation("TournamentRoi")
  purchasedBy        Player?      @relation("PlayerAlliance", fields: [purchasedById], references: [id])
  recruitedPlayers   Player[]     @relation("PlayerAlliance")
  creditPurchases    CreditPurchase[]
  creditPayments     CreditPayment[]
  passwordResetTokens PasswordResetToken[]
}

model TournamentConfig {
  id                String          @id @default("main")
  registrationLimit Int             @default(20)
  stage             TournamentStage @default(REGISTRATION)
  activeRoiId       String?
  lockedAt          DateTime?
  startedAt         DateTime?
  finalizedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  activeRoi Player? @relation("TournamentRoi", fields: [activeRoiId], references: [id])
}

model Match {
  id        String      @id @default(cuid())
  player1Id String
  player2Id String
  winnerId  String?
  status    MatchStatus @default(PENDING)
  date      DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  player1 Player  @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2 Player  @relation("MatchPlayer2", fields: [player2Id], references: [id])
  winner  Player? @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([status, date])
}

model Challenge {
  id          String          @id @default(cuid())
  challengerId String
  defenderId  String
  status      ChallengeStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  challenger Player @relation("ChallengeChallenger", fields: [challengerId], references: [id])
  defender   Player @relation("ChallengeDefender", fields: [defenderId], references: [id])

  @@index([status, createdAt])
}

model CreditPurchase {
  id        String   @id @default(cuid())
  playerId  String
  packKey   String
  credits   Int
  priceFcfa Int
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, packKey, createdAt])
}

model CreditProduct {
  id                 String   @id @default(cuid())
  key                String   @unique
  label              String
  credits            Int
  priceFcfa          Int
  maxPurchasesPerPlayer Int?
  description        String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive, credits])
}

model CreditPayment {
  id                    String   @id @default(cuid())
  playerId              String
  packKey               String
  credits               Int
  amountFcfa            Int
  provider              String   @default("FEDAPAY")
  merchantReference     String   @unique
  status                String   @default("PENDING")
  fedapayTransactionId  String?  @unique
  fedapayTransactionKey String?
  fedapayReference      String?
  fedapayPaymentToken   String?
  checkoutUrl           String?
  callbackUrl           String?
  lastEventName         String?
  failureReason         String?
  rawTransaction        Json?
  rawToken              Json?
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, status, createdAt])
  @@index([packKey, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  playerId   String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, expiresAt])
}

model NotificationDispatch {
  id        String   @id @default(cuid())
  eventKey  String   @unique
  type      String
  status    String   @default("PENDING")
  payload   Json?
  lastError String?
  sentAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, createdAt])
}
